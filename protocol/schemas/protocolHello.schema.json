{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lanchat-next.local/protocol/schemas/protocolHello.schema.json",
  "title": "LanChat protocolHello",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "version"
  ],
  "properties": {
    "type": {
      "const": 50
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    },
    "msg_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "min_version": {
      "type": "integer",
      "minimum": 1
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "status": {
      "enum": [
        "ok",
        "error",
        "failed",
        "start",
        "done"
      ]
    },
    "msg": {
      "type": "string",
      "maxLength": 65536
    }
  },
  "$defs": {
    "user": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nickname"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "nickname": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "headId": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "enum": [
            "ok",
            "error",
            "failed",
            "start",
            "done"
          ]
        }
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "groupId",
        "name"
      ],
      "properties": {
        "groupId": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "hostId": {
          "type": "integer",
          "minimum": 1
        },
        "users": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/user"
          }
        }
      }
    }
  }
}
