{
  "version": "1.2.0",
  "schemaDraft": "https://json-schema.org/draft/2020-12/schema",
  "schemaBaseId": "https://lanchat-next.local/protocol/schemas/",
  "commonFields": ["timestamp", "msg_id"],
  "fields": {
    "type": { "schema": { "type": "integer", "minimum": 0, "maximum": 42 }, "ts": "MsgType" },
    "timestamp": { "schema": { "type": "integer", "minimum": 0 }, "ts": "number" },
    "msg_id": { "schema": { "type": "string", "minLength": 1, "maxLength": 128 }, "ts": "string" },
    "id": { "schema": { "type": "integer", "minimum": 1 }, "ts": "number" },
    "password": { "schema": { "type": "string", "minLength": 1, "maxLength": 256 }, "ts": "string" },
    "nickname": { "schema": { "type": "string", "minLength": 1, "maxLength": 64 }, "ts": "string" },
    "headId": { "schema": { "type": "integer", "minimum": 0 }, "ts": "number" },
    "hostId": { "schema": { "type": "integer", "minimum": 1 }, "ts": "number" },
    "hostNickname": { "schema": { "type": "string", "minLength": 1, "maxLength": 64 }, "ts": "string" },
    "hostHeadId": { "schema": { "type": "integer", "minimum": 0 }, "ts": "number" },
    "fromId": { "schema": { "type": "integer", "minimum": 1 }, "ts": "number" },
    "toId": { "schema": { "type": "integer", "minimum": 1 }, "ts": "number" },
    "groupId": { "schema": { "type": "integer", "minimum": 1 }, "ts": "number" },
    "name": { "schema": { "type": "string", "minLength": 1, "maxLength": 128 }, "ts": "string" },
    "msg": { "schema": { "type": "string", "maxLength": 65536 }, "ts": "string" },
    "content_type": { "schema": { "enum": ["text", "image", "file", "system"] }, "ts": "ContentType" },
    "reply_to": { "schema": { "type": "string", "minLength": 1, "maxLength": 128 }, "ts": "string" },
    "users": { "schema": { "type": "array", "items": { "$ref": "#/$defs/user" } }, "ts": "UserInfo[]" },
    "friends": { "schema": { "type": "array", "items": { "$ref": "#/$defs/user" } }, "ts": "UserInfo[]" },
    "groups": { "schema": { "type": "array", "items": { "$ref": "#/$defs/group" } }, "ts": "GroupInfo[]" },
    "messages": { "schema": { "type": "array", "items": { "type": "object" } }, "ts": "Record<string, unknown>[]" },
    "status": { "schema": { "enum": ["ok", "error", "failed", "start", "done"] }, "ts": "ProtocolStatus" },
    "code": { "schema": { "type": "integer", "minimum": 100, "maximum": 599 }, "ts": "number" },
    "request_id": { "schema": { "type": "string", "minLength": 1, "maxLength": 128 }, "ts": "string" },
    "ai_type": { "schema": { "enum": ["summarize", "translate", "search", "chat"] }, "ts": "AIRequestType" },
    "chunk_index": { "schema": { "type": "integer", "minimum": 0 }, "ts": "number" },
    "is_final": { "schema": { "type": "boolean" }, "ts": "boolean" },
    "file_name": { "schema": { "type": "string", "minLength": 1, "maxLength": 255 }, "ts": "string" },
    "file_size": { "schema": { "type": "integer", "minimum": 0 }, "ts": "number" },
    "file_hash": { "schema": { "type": "string", "minLength": 1, "maxLength": 128 }, "ts": "string" },
    "limit": { "schema": { "type": "integer", "minimum": 1, "maximum": 200 }, "ts": "number" },
    "cursor": { "schema": { "type": "string", "maxLength": 256 }, "ts": "string" },
    "has_more": { "schema": { "type": "boolean" }, "ts": "boolean" },
    "requestId": { "schema": { "type": "string", "minLength": 1, "maxLength": 128 }, "ts": "string" },
    "friendId": { "schema": { "type": "integer", "minimum": 1 }, "ts": "number" }
  },
  "messages": [
    { "name": "RegisterUser", "schemaName": "registerUser", "value": 0, "required": ["password", "nickname"], "optional": ["headId"] },
    { "name": "RegisterUserReturn", "schemaName": "registerUserReturn", "value": 1, "required": ["status"], "optional": ["id", "msg", "code"] },
    { "name": "Login", "schemaName": "login", "value": 2, "required": ["id", "password"], "optional": [] },
    { "name": "LoginSuccessReturn", "schemaName": "loginSuccessReturn", "value": 3, "required": ["id", "nickname", "headId"], "optional": ["friends", "groups", "users"] },
    { "name": "LoginFailedReturn", "schemaName": "loginFailedReturn", "value": 4, "required": ["status", "msg"], "optional": ["code"] },
    { "name": "SendMsg", "schemaName": "sendMsg", "value": 5, "required": ["fromId", "toId", "msg"], "optional": ["content_type", "reply_to"] },
    { "name": "ReceiveMsg", "schemaName": "receiveMsg", "value": 6, "required": ["fromId", "toId", "msg"], "optional": ["id", "nickname", "headId", "content_type", "reply_to"] },
    { "name": "UserOnline", "schemaName": "userOnline", "value": 7, "required": ["id"], "optional": ["nickname", "headId"] },
    { "name": "UserOffline", "schemaName": "userOffline", "value": 8, "required": ["id"], "optional": ["nickname"] },
    { "name": "CreateGroup", "schemaName": "createGroup", "value": 9, "required": ["hostId", "name"], "optional": ["hostNickname", "hostHeadId"] },
    { "name": "CreateGroupReturn", "schemaName": "createGroupReturn", "value": 10, "required": ["status"], "optional": ["groupId", "name", "msg", "code"] },
    { "name": "SearchGroup", "schemaName": "searchGroup", "value": 11, "required": ["name"], "optional": ["limit"] },
    { "name": "SearchGroupReturn", "schemaName": "searchGroupReturn", "value": 12, "required": ["groups"], "optional": ["status", "msg"] },
    { "name": "JoinGroup", "schemaName": "joinGroup", "value": 13, "required": ["id", "groupId"], "optional": [] },
    { "name": "JoinGroupReturn", "schemaName": "joinGroupReturn", "value": 14, "required": ["status", "groupId"], "optional": ["users", "msg", "code"] },
    { "name": "LeaveGroup", "schemaName": "leaveGroup", "value": 15, "required": ["id", "groupId"], "optional": [] },
    { "name": "SendGroupMsg", "schemaName": "sendGroupMsg", "value": 16, "required": ["fromId", "groupId", "msg"], "optional": ["content_type", "reply_to"] },
    { "name": "ReceiveGroupMsg", "schemaName": "receiveGroupMsg", "value": 17, "required": ["fromId", "groupId", "msg"], "optional": ["nickname", "headId", "content_type", "reply_to"] },
    { "name": "UserJoinGroup", "schemaName": "userJoinGroup", "value": 18, "required": ["id", "groupId"], "optional": ["nickname", "headId"] },
    { "name": "UserLeaveGroup", "schemaName": "userLeaveGroup", "value": 19, "required": ["id", "groupId"], "optional": ["nickname"] },
    { "name": "Heartbeat", "schemaName": "heartbeat", "value": 20, "required": [], "optional": [] },
    { "name": "HeartbeatAck", "schemaName": "heartbeatAck", "value": 21, "required": ["status"], "optional": [] },
    { "name": "OfflineMessages", "schemaName": "offlineMessages", "value": 22, "required": ["messages"], "optional": [] },
    { "name": "Logout", "schemaName": "logout", "value": 23, "required": ["id"], "optional": [] },
    { "name": "RequestHistory", "schemaName": "requestHistory", "value": 24, "required": ["id"], "optional": ["toId", "groupId", "limit", "cursor"] },
    { "name": "HistoryResponse", "schemaName": "historyResponse", "value": 25, "required": ["messages"], "optional": ["cursor", "has_more"] },
    { "name": "SendFile", "schemaName": "sendFile", "value": 26, "required": ["fromId", "file_name", "file_size", "file_hash"], "optional": ["toId", "groupId", "msg"] },
    { "name": "ReceiveFile", "schemaName": "receiveFile", "value": 27, "required": ["fromId", "file_name", "file_size", "file_hash"], "optional": ["toId", "groupId", "msg"] },
    { "name": "FileTransferDone", "schemaName": "fileTransferDone", "value": 28, "required": ["status", "file_hash"], "optional": ["msg", "code"] },
    { "name": "AIRequest", "schemaName": "aiRequest", "value": 29, "required": ["request_id", "ai_type", "msg"], "optional": [] },
    { "name": "AIResponse", "schemaName": "aiResponse", "value": 30, "required": ["request_id", "status"], "optional": ["msg", "code"] },
    { "name": "AIStreamChunk", "schemaName": "aiStreamChunk", "value": 31, "required": ["request_id", "chunk_index", "is_final", "msg"], "optional": [] },
    { "name": "UserProfileUpdate", "schemaName": "userProfileUpdate", "value": 32, "required": ["id"], "optional": ["nickname", "headId"], "anyOf": [["nickname"], ["headId"]] },
    { "name": "SystemBroadcast", "schemaName": "systemBroadcast", "value": 33, "required": ["msg"], "optional": ["content_type", "status", "code"] },
    { "name": "FriendRequest", "schemaName": "friendRequest", "value": 34, "required": ["fromId", "toId"], "optional": ["msg"] },
    { "name": "FriendRequestAck", "schemaName": "friendRequestAck", "value": 35, "required": ["requestId", "status"], "optional": ["msg", "code"] },
    { "name": "FriendAccept", "schemaName": "friendAccept", "value": 36, "required": ["fromId", "toId"], "optional": [] },
    { "name": "FriendAcceptReturn", "schemaName": "friendAcceptReturn", "value": 37, "required": ["status", "friendId"], "optional": ["nickname", "headId", "msg", "code"] },
    { "name": "FriendRemove", "schemaName": "friendRemove", "value": 38, "required": ["fromId", "toId"], "optional": [] },
    { "name": "FriendRemoveReturn", "schemaName": "friendRemoveReturn", "value": 39, "required": ["status"], "optional": ["friendId", "msg", "code"] },
    { "name": "FriendList", "schemaName": "friendList", "value": 40, "required": ["id"], "optional": [] },
    { "name": "FriendListReturn", "schemaName": "friendListReturn", "value": 41, "required": ["friends"], "optional": [] },
    { "name": "FriendOnline", "schemaName": "friendOnline", "value": 42, "required": ["friendId", "status"], "optional": ["nickname", "headId"] }
  ]
}
