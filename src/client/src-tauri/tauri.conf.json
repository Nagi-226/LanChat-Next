{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LanChat-Next",
  "version": "1.1.0",
  "identifier": "com.nagi.lanchat-next",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LanChat-Next",
        "width": 1180,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
