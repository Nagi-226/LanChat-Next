   <string notr="true">QDialog#ChatDialog {
    background: #1a1a2e;
}
QFrame#frameChatShell {
    background: #16213e;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 18px;
}
QFrame#frameMessageArea {
    background: rgba(0,0,0,0.12);
    border-radius: 14px;
}
QLabel#labelChatTitle {
    color: #ffffff;
    font-size: 18px;
    font-weight: bold;
}
QLabel#labelChatMeta, QLabel#labelHint {
    color: #a0a0a0;
}
QTextEdit#textEdit {
    background: #1e2a45;
    color: #e0e0e0;
    border: 1px solid #0f3460;
    border-radius: 12px;
    padding: 10px 12px;
}
QPushButton#pushButton_send {
    min-height: 40px;
}
QPushButton#pushButton_brow, QPushButton#pushButton_2 {
    min-height: 34px;
    min-width: 90px;
}
</string>
